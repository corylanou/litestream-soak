  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "links": [
    {
      "targetBlank": true,
      "title": "Overview Dashboard",
      "type": "link",
      "url": "/d/litestream-soak-overview?var-source=${source}&var-worker=${worker}"
    },
    {
      "targetBlank": true,
      "title": "Control Plane",
      "type": "link",
      "url": "https://litestream-soak-ctl.fly.dev/ui"
    },
    {
