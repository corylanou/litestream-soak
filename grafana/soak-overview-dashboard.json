          "expr": "label_replace(sum by (worker_id) ((((soak_control_worker_status{status=\"running\"} == 1) * 1) or ((soak_control_worker_status{status=\"degraded\"} == 1) * 2) or ((soak_control_worker_status{status=\"dormant\"} == 1) * 3) or ((soak_control_worker_status{status=\"probing\"} == 1) * 4) or ((soak_control_worker_status{status=\"pending\"} == 1) * 5) or ((soak_control_worker_status{status=\"building\"} == 1) * 6) or ((soak_control_worker_status{status=\"starting\"} == 1) * 7) or ((soak_control_worker_status{status=\"stopped\"} == 1) * 8) or ((soak_control_worker_status{status=\"failed\"} == 1) * 9))), \"worker\", \"$1\", \"worker_id\", \"worker-main-(.*)\")",
          "legendFormat": "{{worker}}"
        }
      ],
