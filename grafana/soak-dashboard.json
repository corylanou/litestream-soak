{
  "annotations": {
    "list": []
  },
  "description": "Worker-labeled signal board for the Litestream soak project. Use Grafana to see fleet posture, workload shape, drift, lag, and restarts. Use the control plane for incident detail and prompt export.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "links": [
    {
      "targetBlank": true,
      "title": "Control Plane",
      "type": "link",
      "url": "https://litestream-soak-ctl.fly.dev/ui"
    },
    {
      "targetBlank": true,
      "title": "Selected Worker",
      "type": "link",
      "url": "https://litestream-soak-ctl.fly.dev/ui/workers/${worker}"
    },
    {
      "targetBlank": true,
      "title": "Prompt Bundle",
      "type": "link",
      "url": "https://litestream-soak-ctl.fly.dev/api/workers/${worker}/prompt"
    },
    {
      "targetBlank": true,
      "title": "Failure Feed",
      "type": "link",
      "url": "https://litestream-soak-ctl.fly.dev/api/failures"
    }
  ],
