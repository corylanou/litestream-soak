{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Worker Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "soak_worker_info",
          "legendFormat": "{{worker_id}} ({{profile}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Running", "color": "green" } } }]
        }
      }
    },
    {
      "title": "Worker Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "soak_worker_uptime_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Last Verification",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "soak_verification_last_result",
          "legendFormat": "result"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASS", "color": "green" }, "0": { "text": "FAIL", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Load Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "soak_load_running",
          "legendFormat": "load"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Running", "color": "green" }, "0": { "text": "Paused", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Verification Results",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "increase(soak_verification_total[5m])",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "passed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Verification Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(soak_verification_duration_seconds_sum[5m]) / rate(soak_verification_duration_seconds_count[5m])",
          "legendFormat": "avg duration"
        },
        {
          "expr": "histogram_quantile(0.99, rate(soak_verification_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "soak_db_size_bytes",
          "legendFormat": "{{db}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "WAL Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "soak_wal_size_bytes",
          "legendFormat": "{{db}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Transaction ID",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "soak_db_txid",
          "legendFormat": "{{db}}"
        }
      ]
    },
    {
      "title": "Replication Lag (TXIDs)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "soak_replication_lag_txids",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "lag" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Replicated TXID vs DB TXID",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "soak_db_txid",
          "legendFormat": "db txid"
        },
        {
          "expr": "soak_replicated_txid",
          "legendFormat": "replicated txid"
        }
      ]
    },
    {
      "title": "Last Sync Age",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "targets": [
        {
          "expr": "soak_last_sync_age_seconds",
          "legendFormat": "seconds since last sync"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Litestream Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "soak_litestream_uptime_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "DB Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 28 },
      "targets": [
        {
          "expr": "soak_db_status",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Active", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "TXID Rate (writes/sec estimate)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 28 },
      "targets": [
        {
          "expr": "rate(soak_db_txid[5m])",
          "legendFormat": "txid/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["litestream", "soak"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Litestream Soak Testing",
  "uid": "litestream-soak"
}
